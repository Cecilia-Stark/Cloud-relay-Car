# Token signing secret for login sessions. Use a long random value in production.
AUTH_SECRET=change-this-session-signing-secret

# Role-specific invitation codes. Registration only succeeds when the selected
# role matches one of these codes.
OPERATOR_INVITE_CODE=change-this-operator-code
DISPATCHER_INVITE_CODE=change-this-dispatcher-code
VIEWER_INVITE_CODE=change-this-viewer-code

# Optional shared invitation code accepted for every role.
# PLATFORM_INVITE_CODE=change-this-shared-code

# Do not use VITE_* values as invitation codes; they are bundled into the client.

# Live video sources exposed by SRS HTTP-FLV. The robot pushes its camera to
# rtmp://<server>:1935/live/car_front, which SRS remuxes to the first URL.
VITE_STREAM_HOST=119.45.14.204
VITE_CAR_CAMERA_URL=/live/car.flv
VITE_ROADSIDE_CAMERA_URL=/live/car_front.flv
# VITE_WIDE_CAMERA_URL=http://119.45.14.204:8088/live/wide.flv

# Recording input used by replay-server.js. Keep this aligned with the car
# camera URL, but use localhost from the server itself.
RECORDING_INPUT_URL=http://127.0.0.1:8088/live/car_front.flv
