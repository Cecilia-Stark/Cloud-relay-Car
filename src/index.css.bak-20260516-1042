.takeover-confirm-close {
  position: absolute;
  top: 0.9rem;
  right: 0.9rem;
  display: grid;
  place-items: center;
  width: 2rem;
  height: 2rem;
  color: #cbd5e1;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 0.5rem;
}

.takeover-confirm-icon {
  display: grid;
  place-items: center;
  width: 3.25rem;
  height: 3.25rem;
  margin-bottom: 1rem;
  color: #fecaca;
  background: rgba(127, 29, 29, 0.42);
  border: 1px solid rgba(248, 113, 113, 0.32);
  border-radius: 0.85rem;
}

.takeover-confirm-panel h2 {
  margin: 0 2.3rem 0.55rem 0;
  font-size: 1.25rem;
  font-weight: 900;
}

.takeover-confirm-panel p {
  margin: 0;
  color: #94a3b8;
  font-size: 0.92rem;
  line-height: 1.65;
}

.takeover-confirm-actions {
  display: flex;
  justify-content: flex-end;
  gap: 0.75rem;
  margin-top: 1.35rem;
}

.takeover-confirm-actions button {
  min-width: 6.6rem;
  min-height: 2.65rem;
  border-radius: 0.62rem;
  font-weight: 850;
}

.takeover-confirm-cancel {
  color: #cbd5e1;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.takeover-confirm-submit {
  color: #ffffff;
  background: linear-gradient(135deg, #991b1b, #dc2626);
  border: 1px solid rgba(254, 202, 202, 0.3);
  box-shadow: 0 0.75rem 1.8rem rgba(127, 29, 29, 0.34);
}

.control-real-pedal-control {
  display: grid;
  grid-template-columns: auto auto;
  grid-template-rows: auto minmax(0, 1fr) auto;
  justify-content: center;
  align-items: center;
  column-gap: 0.75rem;
  height: 100%;
}

.control-real-pedal-control > div:first-child,
.control-real-pedal-control > div:last-child {
  grid-column: 1 / -1;
  justify-self: center;
}

.control-real-pedal {
  display: grid;
  grid-template-columns: repeat(4, 0.25rem);
  grid-auto-rows: 0.25rem;
  gap: 0.3rem;
  align-content: center;
  justify-content: center;
  width: 3.8rem;
  height: 5.8rem;
  border-radius: 0.4rem 0.4rem 0.7rem 0.7rem;
  background: linear-gradient(145deg, #f8fafc 0%, #9ca3af 48%, #374151 100%);
  border: 1px solid rgba(15, 23, 42, 0.35);
  box-shadow:
    inset 0.25rem 0.25rem 0.55rem rgba(255, 255, 255, 0.38),
    inset -0.32rem -0.42rem 0.7rem rgba(15, 23, 42, 0.55),
    0 0.8rem 1.4rem rgba(0, 0, 0, 0.35);
}

.control-real-pedal-narrow {
  width: 3rem;
  height: 6.2rem;
}

.control-real-pedal i {
  width: 0.25rem;
  height: 0.25rem;
  border-radius: 999px;
  background: #111827;
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.28);
}

.control-pedal-progress {
  position: relative;
  width: 0.55rem;
  height: 5.5rem;
  overflow: hidden;
  background: #111827;
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 999px;
}

.control-pedal-progress div {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: inherit;
  transition: height 75ms linear;
}

.control-real-wheel {
  position: relative;
  width: 7.4rem;
  aspect-ratio: 1;
  filter: drop-shadow(0 0.9rem 1.2rem rgba(0, 0, 0, 0.45));
}

.control-real-wheel-rim {
  position: absolute;
  inset: 0;
  border-radius: 999px;
  background:
    radial-gradient(circle at center, transparent 0 47%, #111827 48% 59%, #4b5563 60% 67%, #06080c 68% 100%);
  border: 0.25rem solid #20242c;
  box-shadow:
    inset 0.3rem 0.5rem 0.8rem rgba(255, 255, 255, 0.18),
    inset -0.35rem -0.5rem 0.8rem rgba(0, 0, 0, 0.65);
}

.control-real-wheel-hub {
  position: absolute;
  inset: 35%;
  z-index: 3;
  display: grid;
  place-items: center;
  color: #f8fafc;
  background: radial-gradient(circle at 35% 30%, #737b8a, #1f2937 58%, #0b0f17 100%);
  border: 0.17rem solid #7b8494;
  border-radius: 999px;
  font-size: 0.62rem;
  font-weight: 900;
}

.control-real-spoke {
  position: absolute;
  z-index: 2;
  left: 50%;
  top: 50%;
  width: 34%;
  height: 0.58rem;
  transform-origin: left center;
  background: linear-gradient(180deg, #aab1bd, #343b46);
  border-radius: 999px;
}

.control-real-spoke-left {
  transform: rotate(185deg);
}

.control-real-spoke-right {
  transform: rotate(-5deg);
}

.control-real-spoke-bottom {
  transform: rotate(90deg);
}

.control-real-wheel-marker {
  position: absolute;
  top: 0.34rem;
  left: 50%;
  z-index: 4;
  width: 0.34rem;
  height: 0.9rem;
  transform: translateX(-50%);
  background: #ef4444;
  border-radius: 999px;
}

.control-steering-progress {
  width: min(11rem, 78%);
  height: 0.5rem;
  margin-top: 0.55rem;
  overflow: hidden;
  background: #111827;
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 999px;
}

.control-steering-progress div {
  height: 100%;
  background: linear-gradient(90deg, #7c8cff, #38bdf8);
  border-radius: inherit;
  transition: width 75ms linear;
}

@media (max-width: 1440px) {
  .control-layout {
    grid-template-columns: minmax(13.5rem, 21%) minmax(0, 1fr) minmax(13.5rem, 21%);
  }

  .control-input-deck {
    width: min(calc(100% - 1.5rem), 48rem);
    height: clamp(7.6rem, 17vh, 9.25rem);
  }

  .control-end-takeover-bar {
    bottom: clamp(9.2rem, 19vh, 11.2rem);
  }

  .control-real-wheel {
    width: clamp(5.9rem, 10.5vh, 7rem);
  }

  .control-real-pedal {
    height: clamp(4.7rem, 8vh, 5.6rem);
  }

  .control-real-pedal-narrow {
    height: clamp(5rem, 8.4vh, 5.9rem);
  }
}

@media (max-width: 1180px) {
  .control-layout {
    grid-template-columns: minmax(11.5rem, 18%) minmax(0, 1fr) minmax(11.5rem, 18%);
  }

  .control-network-card {
    left: 0.35rem;
    right: 0.35rem;
  }

  .control-network-card span {
    max-width: 8.5rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .control-input-deck {
    width: min(calc(100% - 1rem), 42rem);
    padding-inline: 1rem !important;
  }

  .control-end-takeover-button {
    min-width: 12.6rem;
    min-height: 3.45rem;
    padding-inline: 1.65rem;
    font-size: 1.05rem;
  }
}

@media (max-height: 820px) {
  .control-input-deck {
    bottom: 0.6rem;
    height: clamp(6.9rem, 18vh, 8.5rem);
  }

  .control-end-takeover-bar {
    bottom: clamp(8.2rem, 20vh, 9.8rem);
  }

  .control-end-takeover-button {
    min-height: 3.25rem;
  }

  .control-real-wheel {
    width: clamp(5.4rem, 10.5vh, 6.7rem);
  }

  .control-real-pedal {
    height: clamp(4.4rem, 8vh, 5.1rem);
  }

  .control-pedal-progress {
    height: clamp(4.2rem, 7.6vh, 5rem);
  }
}

@media (min-width: 2400px) and (min-aspect-ratio: 21 / 9) {
  .control-layout {
    grid-template-columns: minmax(42rem, 19vw) minmax(0, 1fr) minmax(42rem, 19vw);
  }

  .control-input-deck {
    width: min(64rem, 34vw);
    height: clamp(10rem, 14vh, 12rem);
    bottom: clamp(1.2rem, 2vh, 1.8rem);
  }

  .control-end-takeover-bar {
    bottom: clamp(13rem, 17vh, 15rem);
  }

  .control-real-wheel {
    width: clamp(7.4rem, 8.2vh, 9.2rem);
  }

  .control-real-pedal {
    height: clamp(5.8rem, 7.4vh, 7rem);
  }

  .control-real-pedal-narrow {
    height: clamp(6.1rem, 7.8vh, 7.4rem);
  }
}

.map3d-shell {
  position: relative;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  min-height: 18rem;
  overflow: hidden;
  background: #06101f;
  color: #e5edf8;
}

.map3d-canvas-wrap {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: #07111f;
}

.map3d-canvas {
  width: 100%;
  height: 100%;
  min-height: 18rem;
  background: #07111f;
  filter: brightness(0.66) contrast(1.14) saturate(1.18);
}

.map3d-vignette,
.map3d-top-fade,
.map3d-bottom-fade {
  position: absolute;
  pointer-events: none;
  z-index: 10;
}

.map3d-vignette {
  inset: 0;
  background:
    radial-gradient(circle at 50% 52%, transparent 0 22%, rgba(3, 7, 18, 0.18) 54%, rgba(3, 7, 18, 0.52) 100%),
    linear-gradient(180deg, rgba(5, 10, 20, 0.38), transparent 42%, rgba(5, 10, 20, 0.28));
}

.map3d-top-fade {
  inset: 0 0 auto;
  height: 44%;
  background: linear-gradient(180deg, rgba(6, 16, 31, 0.92), rgba(6, 16, 31, 0.42), transparent);
}

.map3d-bottom-fade {
  inset: auto 0 0;
  height: 50%;
  background: linear-gradient(0deg, rgba(2, 8, 23, 0.82), rgba(2, 8, 23, 0.24), transparent);
}

.map3d-error {
  position: absolute;
  inset: 0;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  padding: 1.5rem;
  color: #94a3b8;
  text-align: center;
  background: rgba(15, 23, 42, 0.92);
}

.map3d-error svg {
  color: #ef4444;
}

.map3d-layer-badge,
.map3d-follow-badge,
.map3d-controls {
  position: absolute;
  z-index: 20;
}

.map3d-layer-badge {
  left: 1rem;
  bottom: 1rem;
  pointer-events: none;
}

.map3d-follow-badge {
  left: 1rem;
  bottom: 3.55rem;
  pointer-events: none;
}

.map3d-layer-badge > span,
.map3d-follow-badge > span {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.45rem 0.65rem;
  color: #dbeafe;
  background: rgba(2, 6, 23, 0.74);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 0.55rem;
  backdrop-filter: blur(8px);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.02em;
}

.map3d-layer-badge svg {
  color: #8ee7ff;
}

.map3d-follow-badge svg {
  color: #bfdbfe;
}

.map3d-controls {
  right: 1rem;
  bottom: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.map3d-zoom {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 0.7rem;
  box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.34);
}

.map3d-zoom button,
.map3d-round-button {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: rgba(2, 6, 23, 0.82);
  border: 0;
  transition: background 160ms ease, transform 160ms ease;
  pointer-events: auto;
}

.map3d-zoom button {
  width: 2.45rem;
  height: 2.45rem;
  font-size: 1.15rem;
  font-weight: 900;
}

.map3d-zoom button + button {
  border-top: 1px solid rgba(255, 255, 255, 0.12);
}

.map3d-round-button {
  width: 2.7rem;
  height: 2.7rem;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 999px;
  box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.34);
}

.map3d-round-button svg {
  transition: transform 0.5s ease;
}

.map3d-zoom button:hover,
.map3d-round-button:hover {
  background: rgba(30, 41, 59, 0.92);
  transform: translateY(-1px);
}

.map3d-follow-button {
  color: #06101f;
  background: rgba(34, 211, 238, 0.94);
  border-color: rgba(165, 243, 252, 0.9);
}

.map3d-follow-button:hover {
  background: rgba(103, 232, 249, 0.98);
}

