    radial-gradient(circle at 62% 34%, rgba(17, 24, 39, 0.08), transparent 24rem),
    linear-gradient(135deg, #ffffff, #f5f6f8 48%, #e8ebef);
}

.control-layout {
  display: grid;
  grid-template-columns: minmax(16rem, 20%) minmax(0, 1fr) minmax(16rem, 20%);
  height: 100%;
  min-height: 0;
  background:
    linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
