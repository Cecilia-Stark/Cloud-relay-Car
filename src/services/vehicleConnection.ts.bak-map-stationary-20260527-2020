import { G29Input, RobotTelemetry, VehicleStatus, VehicleTelemetry } from '../types';

type TelemetryCallback = (data: VehicleTelemetry) => void;

const DEFAULT_LAT = 32.1565;
const DEFAULT_LNG = 118.7076;
const POSITION_OFFSET_NORTH_METERS = 460;
const POSITION_OFFSET_WEST_METERS = -580;
const METERS_PER_DEG_LAT = 111320;
const POLL_INTERVAL_MS = 200;
const VEHICLE_WHEELBASE_METERS = 1.2;
const MAX_ROAD_WHEEL_DEGREES = 35;
const G29_DEMO_MIN_SPEED_MPS = 1.2;
const G29_DEMO_MAX_SPEED_MPS = 3.0;
const BATTERY_EMPTY_VOLTAGE = 20.0;
const BATTERY_FULL_VOLTAGE = 25.6;
const ORIGIN_LAT = DEFAULT_LAT + POSITION_OFFSET_NORTH_METERS / METERS_PER_DEG_LAT;
const ORIGIN_LNG = DEFAULT_LNG - POSITION_OFFSET_WEST_METERS / (METERS_PER_DEG_LAT * Math.cos(DEFAULT_LAT * Math.PI / 180));
const METERS_PER_DEG_LNG_AT_ORIGIN = METERS_PER_DEG_LAT * Math.cos(ORIGIN_LAT * Math.PI / 180);
const POSITION_MOVE_EPSILON_METERS = 0.02;

function getRelayStatusUrl(): string {
  return '/api/status';
}

function voltageToBatteryPercentage(voltage: number): number {
  if (!Number.isFinite(voltage)) return 0;
  const percent = (voltage - BATTERY_EMPTY_VOLTAGE) / (BATTERY_FULL_VOLTAGE - BATTERY_EMPTY_VOLTAGE) * 100;
  return Math.min(100, Math.max(0, percent));
}

function clamp(value: number, min: number, max: number) {
  return Math.min(max, Math.max(min, value));
}

function finiteNumber(value: unknown, fallback = 0) {
  const n = Number(value);
  return Number.isFinite(n) ? n : fallback;
}

function degreesToRadians(value: number) {
  return value * Math.PI / 180;
}

function isReverseGear(gear: unknown) {
  const normalized = String(gear ?? '').trim().toLowerCase();
  return normalized === 'r' || normalized === 'reverse' || normalized === '-1';
}

class VehicleConnectionService {
  private subscribers: TelemetryCallback[] = [];
  private intervalId: ReturnType<typeof setInterval> | null = null;
  private currentData: VehicleTelemetry = this.emptyTelemetry();
  private isSimulatingAnomaly = false;
  private demoPose = { x: 0, y: 0, yaw: 0 };
  private lastRobotPose: { x: number; y: number; yaw: number } | null = null;
  private lastDemoUpdateMs = Date.now();

  private emptyTelemetry(): VehicleTelemetry {
    return {
      timestamp: Date.now(),
      robot: null,
      robotConnected: false,
      g29: null,
      speedKmh: 0,
      latitude: ORIGIN_LAT,
      longitude: ORIGIN_LNG,
      status: VehicleStatus.NORMAL
    };
  }

  // ============================================================
  //  Telemetry — poll real relay server
  // ============================================================
  public connect() {
    console.log('正在连接 relay 遥测服务...');
    if (this.intervalId) clearInterval(this.intervalId);

    const poll = async () => {
      try {
        const response = await fetch(getRelayStatusUrl(), { cache: 'no-store' });
        if (!response.ok) throw new Error(`Status ${response.status}`);

        const payload = await response.json();
        const robotConnected = Boolean(payload.robot_connected);
        const raw: RobotTelemetry | null = payload.telemetry?.type === 'telemetry' ? payload.telemetry : null;
        const robotTelemetry: RobotTelemetry | null = raw
          ? {
            ...raw,
            battery: raw.battery
              ? {
                ...raw.battery,
                percentage: voltageToBatteryPercentage(Number(raw.battery.voltage))
              }
              : raw.battery
          }
          : null;
        const g29: G29Input | null = payload.last_g29 || null;

        let speedKmh = 0;
        let lat = ORIGIN_LAT;
        let lng = ORIGIN_LNG;

        if (robotTelemetry) {
          const vehicleSpeed = finiteNumber(robotTelemetry.vehicle?.speed, NaN);
          const rawSpeed = Math.abs(robotTelemetry.velocity?.linear ?? 0);
          speedKmh = Number.isFinite(vehicleSpeed) ? Math.abs(vehicleSpeed) : rawSpeed * 3.6;

          const pose = this.advanceVehiclePose(robotTelemetry, g29);
          lat = ORIGIN_LAT + pose.y / METERS_PER_DEG_LAT;
          lng = ORIGIN_LNG + pose.x / METERS_PER_DEG_LNG_AT_ORIGIN;
        }

        let status = VehicleStatus.NORMAL;
        if (!robotConnected) {
          status = VehicleStatus.DISCONNECTED;
        } else if (this.isSimulatingAnomaly) {
          status = VehicleStatus.CRITICAL;
        }

        this.currentData = {
          timestamp: Date.now(),
          robot: robotTelemetry,
          robotConnected,
          g29,
          speedKmh: Math.round(speedKmh * 10) / 10,
          latitude: lat,
          longitude: lng,
          status,
          errorMessage: this.isSimulatingAnomaly ? '前向雷达遮挡' : undefined
        };

        this.notifySubscribers(this.currentData);
      } catch (err) {
        console.warn('遥测轮询失败:', err);
        this.currentData = {
          ...this.currentData,
          robotConnected: false,
          status: VehicleStatus.DISCONNECTED
        };
        this.notifySubscribers(this.currentData);
      }
    };

    poll(); // immediate first poll
    this.intervalId = setInterval(poll, POLL_INTERVAL_MS);
  }

  public disconnect() {
    if (this.intervalId) clearInterval(this.intervalId);
    this.intervalId = null;
    console.log('遥测连接已关闭');
  }

  public subscribe(callback: TelemetryCallback) {
    this.subscribers.push(callback);
    return () => {
      this.subscribers = this.subscribers.filter(cb => cb !== callback);
    };
  }

  private notifySubscribers(data: VehicleTelemetry) {
    this.subscribers.forEach(cb => cb(data));
  }

  private advanceVehiclePose(robotTelemetry: RobotTelemetry, g29: G29Input | null) {
    const now = Date.now();
    const dt = clamp((now - this.lastDemoUpdateMs) / 1000, 0.02, 0.5);
    this.lastDemoUpdateMs = now;

    const vehicleSpeedKmh = finiteNumber(robotTelemetry.vehicle?.speed, NaN);
    const odomSpeedMps = finiteNumber(robotTelemetry.velocity?.linear, NaN);
    const hasVehicleSpeed = Number.isFinite(vehicleSpeedKmh) && Math.abs(vehicleSpeedKmh) > 0.05;
    const hasOdomSpeed = Number.isFinite(odomSpeedMps) && Math.abs(odomSpeedMps) > 0.02;

    if (!hasVehicleSpeed && !hasOdomSpeed) {
      const directPose = this.resolveDirectRobotPose(robotTelemetry);
      if (directPose) return directPose;

      const demoSpeedMps = this.advanceDemoPoseFromG29(g29, dt);
      return { ...this.demoPose, demoSpeedMps };
    }

    const direction = isReverseGear(robotTelemetry.vehicle?.gear) ? -1 : 1;
    const speedMps = hasVehicleSpeed
      ? Math.abs(vehicleSpeedKmh) / 3.6 * direction
      : odomSpeedMps;
    const steeringDegrees = clamp(
      finiteNumber(robotTelemetry.vehicle?.steering_angle, 0),
      -MAX_ROAD_WHEEL_DEGREES,
      MAX_ROAD_WHEEL_DEGREES
    );
    const steeringRadians = degreesToRadians(steeringDegrees);
    const yawRate = Math.abs(steeringRadians) < 0.001
      ? 0
      : speedMps / VEHICLE_WHEELBASE_METERS * Math.tan(steeringRadians);

    this.demoPose.yaw += yawRate * dt;
    this.demoPose.x += Math.cos(this.demoPose.yaw) * speedMps * dt;
    this.demoPose.y += Math.sin(this.demoPose.yaw) * speedMps * dt;
    return { ...this.demoPose, demoSpeedMps: Math.abs(speedMps) };
  }

  private resolveDirectRobotPose(robotTelemetry: RobotTelemetry) {
    const x = finiteNumber(robotTelemetry.position?.x, NaN);
    const y = finiteNumber(robotTelemetry.position?.y, NaN);
    if (!Number.isFinite(x) || !Number.isFinite(y)) return null;

    const yaw = finiteNumber(robotTelemetry.position?.yaw, this.demoPose.yaw);
    const last = this.lastRobotPose;
    const moved = !last || Math.hypot(x - last.x, y - last.y) > POSITION_MOVE_EPSILON_METERS;
    this.lastRobotPose = { x, y, yaw };

    if (!moved) return null;

    this.demoPose = { x, y, yaw };
    return { ...this.demoPose, demoSpeedMps: 0 };
  }

  private advanceDemoPoseFromG29(g29: G29Input | null, dt: number) {
    if (!g29) return 0;

    const steer = clamp(finiteNumber(g29.steer), -450, 450);
    const throttle = clamp(finiteNumber(g29.throttle), 0, 100);
    const brake = clamp(finiteNumber(g29.brake), 0, 100);
    const steerNorm = clamp(Math.abs(steer) >= 45 ? steer / 450 : steer / 10, -1, 1);
    const steerActivity = Math.abs(steerNorm);
    const throttleActivity = throttle / 100;

    if (brake > 85 || (steerActivity < 0.005 && throttleActivity < 0.015)) {
      return 0;
    }

    const inputActivity = Math.max(throttleActivity, steerActivity * 0.75);
    const brakeScale = clamp(1 - brake / 120, 0.2, 1);
    const speed = Math.max(G29_DEMO_MIN_SPEED_MPS, inputActivity * G29_DEMO_MAX_SPEED_MPS * brakeScale);
    const turnRate = steerNorm * 1.35;

    this.demoPose.yaw += turnRate * dt;
    this.demoPose.x += Math.cos(this.demoPose.yaw) * speed * dt;
    this.demoPose.y += Math.sin(this.demoPose.yaw) * speed * dt;
    return speed;
  }

  // ============================================================
  //  Control commands (unchanged)
  // ============================================================
  public async sendControlCommand(command: string, value: unknown) {
    console.log(`[指令下发 Cloud->Car] ${command}:`, value);
  }

  public async triggerManualTakeover() {
    await this.sendControlCommand('TAKEOVER_REQUEST', true);
  }

  public async triggerControlRelease() {
    if (this.isSimulatingAnomaly) {
      this.isSimulatingAnomaly = false;
      if (this.currentData.robotConnected) {
        this.currentData.status = VehicleStatus.NORMAL;
      }
    }
  }

  public toggleSimulationAnomaly() {
    this.isSimulatingAnomaly = !this.isSimulatingAnomaly;
  }
}

export const vehicleService = new VehicleConnectionService();
