import React, { useCallback, useEffect, useRef, useState } from 'react';
import { Battery, Gauge, Power, Save, Settings, Wifi } from 'lucide-react';
import { HttpFlvPlayer } from '../components/HttpFlvPlayer';
import { MapContainer } from '../components/MapContainer';
import { createRelayConnectionUrl } from '../services/auth';
import { getCarIp, sendStopCommand, sendVelocityCommand, setCarIp } from '../services/carControl';
import { VehicleTelemetry } from '../types';

interface ControlViewProps {
  telemetry: VehicleTelemetry;
  onExitControl: () => void;
}

interface G29State {
  status: 'connected' | 'disconnected' | 'error';
  steering: number;
  throttle: number;
  brake: number;
  message: string;
  updatedAt: number;
}

interface G29RelayStatus {
  latestData?: {
    steering?: number;
    throttle?: number;
    brake?: number;
    updatedAt?: number;
  };
  relayState?: {
    relayEnabled?: boolean;
    enabled?: boolean;
    lastForwardAt?: number;
    lastDelivered?: boolean;
  };
  status?: 'connected' | 'disconnected' | 'error';
  steering?: number;
  throttle?: number;
  brake?: number;
  updatedAt?: number;
  relayEnabled?: boolean;
  message?: string;
}

type ControlTheme = 'dark' | 'light';
const G29_DATA_STALE_MS = 10000;
const KEYBOARD_LINEAR_SPEED = 0.5;

type RecordingTarget = 'vehicle-front' | 'roadside-4g';

interface LocalRecording {
  recorder: MediaRecorder;
  chunks: Blob[];
  filename: string;
}

function getInitialTheme(): ControlTheme {
  try {
    const saved = localStorage.getItem('clouddrive_login_theme');
    if (saved === 'light' || saved === 'dark') return saved;
  } catch {
    // Ignore storage access errors.
  }
  return 'dark';
}

export const ControlView: React.FC<ControlViewProps> = ({ telemetry, onExitControl }) => {
  const [g29Data, setG29Data] = useState<G29State>({
    status: 'disconnected',
    steering: 0,
    throttle: 0,
    brake: 0,
    message: '',
    updatedAt: 0
  });
  const [showSettings, setShowSettings] = useState(false);
  const [carIpInput, setCarIpInput] = useState(getCarIp());
  const [cameraMode, setCameraMode] = useState<'main' | 'wide'>('main');
  const [inputMode, setInputMode] = useState<'g29' | 'keyboard'>('g29');
  const [keyboardData, setKeyboardData] = useState({ throttle: 0, brake: 0 });
  const [theme, setTheme] = useState<ControlTheme>(getInitialTheme);
  const keyboardKeysRef = useRef({ forward: false, backward: false });
  const localRecordingsRef = useRef<Partial<Record<RecordingTarget, LocalRecording>>>({});
  const recordingStartedAtRef = useRef(new Date());

  const streamHost = import.meta.env.VITE_STREAM_HOST || window.location.hostname || '8.149.246.34';
  const carCameraUrl = import.meta.env.VITE_CAR_CAMERA_URL || `/live/car.flv`;
  const wideCameraUrl = import.meta.env.VITE_WIDE_CAMERA_URL || carCameraUrl;
  const roadsideCameraUrl = import.meta.env.VITE_ROADSIDE_CAMERA_URL || `/live/car_front.flv`;
  const displayInput = inputMode === 'keyboard'
    ? {
      status: 'connected' as const,
      steering: 0,
      throttle: keyboardData.throttle,
      brake: keyboardData.brake,
      message: '',
      updatedAt: Date.now()
    }
    : g29Data;
  const steeringProgress = Math.min(100, Math.abs(displayInput.steering) / 450 * 100);

  const sendKeyboardState = useCallback(() => {
    const { forward, backward } = keyboardKeysRef.current;
    const linear = forward && !backward
      ? KEYBOARD_LINEAR_SPEED
      : backward && !forward
        ? -KEYBOARD_LINEAR_SPEED
        : 0;

    setKeyboardData({
      throttle: linear > 0 ? 100 : 0,
      brake: linear < 0 ? 100 : 0
    });

    sendVelocityCommand(linear, 0).catch((error) => {
      console.warn('键盘控制指令发送失败:', error);
    });
  }, []);

  const stopKeyboardControl = useCallback(() => {
    keyboardKeysRef.current = { forward: false, backward: false };
    setKeyboardData({ throttle: 0, brake: 0 });
    sendStopCommand().catch((error) => {
      console.warn('键盘停止指令发送失败:', error);
    });
  }, []);

  const downloadRecording = useCallback((recording: LocalRecording) => {
    if (recording.chunks.length === 0) return;
    const blob = new Blob(recording.chunks, { type: recording.recorder.mimeType || 'video/webm' });
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = recording.filename;
    document.body.appendChild(anchor);
    anchor.click();
    anchor.remove();
    window.setTimeout(() => URL.revokeObjectURL(url), 30000);
  }, []);

  const startLocalRecording = useCallback((target: RecordingTarget, stream: MediaStream | null) => {
    if (!stream || localRecordingsRef.current[target]) return;
    if (!window.MediaRecorder) {
      console.warn('MediaRecorder is not supported by this browser.');
      return;
    }

    const videoTracks = stream.getVideoTracks();
    if (videoTracks.length === 0) return;

    const mimeType = MediaRecorder.isTypeSupported('video/webm;codecs=vp9')
      ? 'video/webm;codecs=vp9'
      : MediaRecorder.isTypeSupported('video/webm;codecs=vp8')
        ? 'video/webm;codecs=vp8'
        : 'video/webm';
    const filenameTime = recordingStartedAtRef.current
      .toISOString()
      .replace(/[:.]/g, '-');
    const chunks: Blob[] = [];
    const recorder = new MediaRecorder(new MediaStream(videoTracks), { mimeType });
    const recording: LocalRecording = {
      recorder,
      chunks,
      filename: `clouddrive-${target}-${filenameTime}.webm`
    };

    recorder.ondataavailable = (event) => {
      if (event.data.size > 0) chunks.push(event.data);
    };
    recorder.onstop = () => {
      downloadRecording(recording);
      delete localRecordingsRef.current[target];
    };
    localRecordingsRef.current[target] = recording;
    recorder.start(1000);
  }, [downloadRecording]);

  const stopLocalRecordings = useCallback(() => {
    const recordings = Object.values(localRecordingsRef.current);
    localRecordingsRef.current = {};
    recordings.forEach((recording) => {
      if (recording.recorder.state === 'inactive') {
        downloadRecording(recording);
        return;
      }
      recording.recorder.stop();
    });
  }, [downloadRecording]);

  const handleRoadsideStream = useCallback((stream: MediaStream | null) => {
    startLocalRecording('roadside-4g', stream);
  }, [startLocalRecording]);

  const handleVehicleFrontStream = useCallback((stream: MediaStream | null) => {
    startLocalRecording('vehicle-front', stream);
  }, [startLocalRecording]);

  useEffect(() => {
    return () => stopLocalRecordings();
  }, [stopLocalRecordings]);

  const relayControlUrl = () => {
    const serverHost = window.location.hostname || streamHost || '8.149.246.34';
    const protocol = window.location.protocol === 'https:' ? 'https:' : 'http:';
    return `${protocol}//${serverHost}/relay-control`;
  };

  const postRelayControl = (action: 'enable' | 'disable', token: string, keepalive = false) => {
    return fetch(relayControlUrl(), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`
      },
      body: JSON.stringify({ action }),
      keepalive
    });
  };

  const updateG29FromRelayStatus = useCallback((payload: G29RelayStatus) => {
    if (payload.status === 'disconnected' || payload.status === 'error') {
      setG29Data((prev) => ({
        ...prev,
        status: payload.status || 'disconnected',
        steering: 0,
        throttle: 0,
        brake: 0,
        message: payload.message || 'G29 relay disconnected.',
        updatedAt: 0
      }));
      return;
    }

    const latestData = payload.latestData || payload;
    const updatedAt = Math.max(
      Number(latestData.updatedAt || 0),
      Number(payload.relayState?.lastForwardAt || 0)
    );
    const relayDelivered = payload.relayState?.lastDelivered === true;
    const isFresh = updatedAt > 0 && Date.now() - updatedAt <= G29_DATA_STALE_MS;

    if (!isFresh && !relayDelivered) {
      setG29Data((prev) => ({
        ...prev,
        status: 'disconnected',
        steering: 0,
        throttle: 0,
        brake: 0,
        message: '等待 G29 实时数据...',
        updatedAt
      }));
      return;
    }

    const relayEnabled = payload.relayState?.enabled ?? payload.relayState?.relayEnabled ?? payload.relayEnabled ?? true;
    setG29Data({
      status: 'connected',
      steering: Number(latestData.steering || 0),
      throttle: Number(latestData.throttle || 0),
      brake: Number(latestData.brake || 0),
      message: relayEnabled ? '' : 'Relay paused until takeover is enabled.',
      updatedAt
    });
  }, []);

  useEffect(() => {
    const readTheme = () => setTheme(getInitialTheme());
    window.addEventListener('storage', readTheme);
    window.addEventListener('focus', readTheme);
    return () => {
      window.removeEventListener('storage', readTheme);
      window.removeEventListener('focus', readTheme);
    };
  }, []);

  useEffect(() => {
    let ws: WebSocket | null = null;
    let relayToken = '';
    let cancelled = false;

    async function connectRelay() {
      try {
        const wsUrl = await createRelayConnectionUrl();
        if (cancelled) return;

        relayToken = new URL(wsUrl).searchParams.get('relayToken') || '';
        if (relayToken) {
          await postRelayControl('enable', relayToken);
        }
        if (cancelled) return;

        ws = new WebSocket(wsUrl);

        ws.onopen = () => {
          setG29Data((prev) => ({ ...prev, status: 'disconnected', message: '等待 G29 实时数据...' }));
        };

        ws.onmessage = (event) => {
          try {
            const data = JSON.parse(event.data);
            updateG29FromRelayStatus(data);
          } catch {
            console.warn('Received invalid G29 data.');
          }
        };

        ws.onerror = () => {
          setG29Data((prev) => ({ ...prev, status: 'disconnected', message: 'G29 WebSocket unavailable; polling status...' }));
        };

        ws.onclose = () => {
          if (!cancelled) {
            setG29Data((prev) => ({ ...prev, status: 'disconnected', message: 'G29 WebSocket disconnected; polling status...' }));
          }
        };
      } catch (error) {
        console.error('G29 relay setup failed:', error);
        setG29Data((prev) => ({ ...prev, status: 'disconnected', message: 'Unable to authorize G29 relay; polling status...' }));
      }
    }

    connectRelay();

    return () => {
      cancelled = true;
      ws?.close();
      if (relayToken) {
        postRelayControl('disable', relayToken, true).catch(() => {});
      }
    };
  }, [updateG29FromRelayStatus]);

  useEffect(() => {
    let cancelled = false;
    const poll = async () => {
      try {
        const response = await fetch('/g29-status', { cache: 'no-store' });
        if (!response.ok) throw new Error(`G29 status failed: ${response.status}`);
        const payload = await response.json();
        if (!cancelled) updateG29FromRelayStatus(payload);
      } catch (error) {
        if (!cancelled) {
          console.warn('G29 status polling failed:', error);
        }
      }
    };

    poll();
    const timer = window.setInterval(poll, 500);
    return () => {
      cancelled = true;
      window.clearInterval(timer);
    };
  }, [updateG29FromRelayStatus]);

  useEffect(() => {
    const timer = window.setInterval(() => {
      setG29Data((prev) => {
        if (prev.status !== 'connected') return prev;
        if (!prev.updatedAt || Date.now() - prev.updatedAt <= G29_DATA_STALE_MS) return prev;
        return {
          ...prev,
          status: 'disconnected',
          steering: 0,
          throttle: 0,
          brake: 0,
          message: '等待 G29 实时数据...'
        };
      });
    }, 500);

    return () => window.clearInterval(timer);
  }, []);

  useEffect(() => {
    const handler = (event: KeyboardEvent) => {
      const target = event.target as HTMLElement | null;
      const tagName = target?.tagName;
      if (tagName === 'INPUT' || tagName === 'TEXTAREA' || tagName === 'SELECT' || tagName === 'BUTTON') return;
      const key = event.key.toLowerCase();
      if (key === 'k' && !event.repeat) {
        event.preventDefault();
        setInputMode((mode) => {
          const nextMode = mode === 'g29' ? 'keyboard' : 'g29';
          if (nextMode === 'g29') stopKeyboardControl();
          return nextMode;
        });
        return;
      }

      if (key === 'a' && !event.repeat) {
        event.preventDefault();
        setCameraMode((mode) => (mode === 'main' ? 'wide' : 'main'));
        return;
      }

      if (inputMode !== 'keyboard') return;
      if (key !== 'w' && key !== 'd') return;
      event.preventDefault();
      if (event.repeat) return;

      if (key === 'w') keyboardKeysRef.current.forward = true;
      if (key === 'd') keyboardKeysRef.current.backward = true;
      sendKeyboardState();
    };

    const upHandler = (event: KeyboardEvent) => {
      const key = event.key.toLowerCase();
      if (inputMode !== 'keyboard') return;
      if (key !== 'w' && key !== 'd') return;
      event.preventDefault();

      if (key === 'w') keyboardKeysRef.current.forward = false;
      if (key === 'd') keyboardKeysRef.current.backward = false;
      sendKeyboardState();
    };

    window.addEventListener('keydown', handler);
    window.addEventListener('keyup', upHandler);
    return () => {
      window.removeEventListener('keydown', handler);
      window.removeEventListener('keyup', upHandler);
    };
  }, [inputMode, sendKeyboardState, stopKeyboardControl]);

  useEffect(() => {
    return () => stopKeyboardControl();
  }, [stopKeyboardControl]);

  return (
    <div className="control-theme flex flex-col h-full overflow-hidden font-tech" data-theme={theme}>
      <div className="control-layout flex-1 min-h-0 relative">
        <div className="control-side-panel control-side-panel-left flex flex-col relative z-20">
            <HttpFlvPlayer
              label="Roadside 4G camera"
              src={roadsideCameraUrl}
              className="h-full"
              onStream={handleRoadsideStream}
            />
        </div>

        <div className="control-main-panel flex flex-col relative">
          <div className="absolute inset-0 z-0">
            {cameraMode === 'main' ? (
              <HttpFlvPlayer
                label="Vehicle front camera"
                src={carCameraUrl}
                className="w-full h-full"
                onStream={handleVehicleFrontStream}
              />
            ) : (
              <HttpFlvPlayer label="Wide camera" src={wideCameraUrl} className="w-full h-full" />
            )}
          </div>

          {false && inputMode === 'g29' && g29Data.status !== 'connected' && (
            <div className="control-disconnected-overlay absolute inset-0 flex flex-col items-center justify-center backdrop-blur-sm z-50">
              <div className="control-disconnected-card p-8 rounded-2xl flex flex-col items-center">
                <Wifi size={64} className="text-red-500 mb-4 animate-pulse" />
                <h2 className="text-2xl font-bold mb-2">G29 wheel disconnected</h2>
                <p className="text-sm mb-6 text-center max-w-md">
                  Check the relay service, USB connection, and port 8082.
                </p>
                <div className="control-status-note text-xs font-mono px-4 py-2 rounded">
                  Current status: {g29Data.message || 'Waiting for connection...'}
                </div>
              </div>
            </div>
          )}


          <div className="control-end-takeover-bar">
            <button
              type="button"
                onClick={() => {
                  stopLocalRecordings();
                  onExitControl();
                }}
              className="control-end-takeover-button"
            >
              <Power size={24} />
              <span>结束接管</span>
            </button>
          </div>
        </div>

        <div className="control-side-panel control-side-panel-right flex flex-col relative z-20">
          <div className="control-network-card absolute top-2 left-2 right-2 z-10 backdrop-blur rounded p-2">
            <div className="control-small-label text-[9px] font-mono mb-1">Vehicle connection</div>
            <div className="flex items-center justify-between">
              <span className="text-[10px] text-blue-400 font-mono">{getCarIp()}:8000</span>
              <button
                type="button"
                onClick={() => setShowSettings(true)}
                className="control-icon-button w-7 h-7 p-0 rounded-md inline-flex items-center justify-center"
                title="Vehicle network settings"
              >
                <Settings size={14} />
              </button>
            </div>
            {telemetry.robot?.battery && (
              <div className="mt-1 flex items-center gap-1.5">
                <Battery size={11} className="text-cyan-400" />
                <span className="text-[10px] font-mono text-cyan-300">
                  {telemetry.robot.battery.voltage.toFixed(1)}V {telemetry.robot.battery.percentage.toFixed(0)}%
                </span>
              </div>
            )}
            <div className="mt-1 flex items-center gap-1.5">
              <Gauge size={11} className="text-yellow-400" />
              <span className="text-[10px] font-mono text-yellow-300">
                速度 {telemetry.speedKmh.toFixed(1)} km/h
              </span>
            </div>
            {telemetry.robot?.position && (
              <div className="mt-1 text-[9px] font-mono text-slate-200">
                x:{telemetry.robot.position.x.toFixed(2)} y:{telemetry.robot.position.y.toFixed(2)} yaw:{telemetry.robot.position.yaw.toFixed(2)}
              </div>
            )}
          </div>
          <MapContainer lat={telemetry.latitude} lng={telemetry.longitude} className="w-full h-full opacity-60" />
        </div>
      </div>

      {showSettings && (
        <div className="control-settings-backdrop fixed inset-0 backdrop-blur-sm z-50 flex items-center justify-center">
          <div className="control-settings-panel rounded-xl p-6 w-96 shadow-2xl">
            <h3 className="text-lg font-bold mb-4 flex items-center gap-2">
              <Settings size={20} className="text-blue-500" />
              Vehicle network
            </h3>

            <label className="control-small-label block text-xs mb-2 font-mono" htmlFor="vehicle-ip">
              Vehicle IP address
            </label>
            <input
              id="vehicle-ip"
              type="text"
              value={carIpInput}
              onChange={(event) => setCarIpInput(event.target.value)}
              placeholder="192.168.1.100"
              className="control-settings-input w-full rounded px-3 py-2 font-mono text-sm focus:outline-none"
            />

            <div className="flex gap-2 mt-5">
              <button
                type="button"
                onClick={() => {
                  setCarIp(carIpInput);
                  setShowSettings(false);
                }}
                className="control-save-button flex-1 py-2 rounded text-sm font-bold transition-colors inline-flex items-center justify-center gap-2"
              >
                <Save size={16} />
                Save
              </button>
              <button
                type="button"
                onClick={() => setShowSettings(false)}
                className="control-cancel-button flex-1 py-2 rounded text-sm font-bold transition-colors"
              >
                Cancel
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};
